# Install as /etc/sulu/market-asset-worker.env owned by root with mode 0600.
MARKET_ASSET_API_ORIGIN=https://api.superlumin.al
MARKET_ASSET_WORKER_ID=asset-worker-eu-1
MARKET_ASSET_WORKER_TOKEN=replace-with-at-least-32-random-characters
MARKET_ASSET_BLENDER_ROOT=/opt/blender-5.2
MARKET_ASSET_BLENDER_BINARY=/opt/blender-5.2/blender
MARKET_ASSET_WORKER_BLENDER_VERSION=5.2.0
MARKET_ASSET_WORKER_BLENDER_BUILD_HASH=replace-with-audited-lowercase-build-hash
